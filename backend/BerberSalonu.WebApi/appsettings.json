{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_HERE;Database=BerberSalonuDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Secret": "SuperSecretSecurityKeyThatIsLongEnoughToMeetRequirements12345!",
    "Issuer": "BerberSalonuApi",
    "Audience": "BerberSalonuClient",
    "ExpiryInDays": 30
  },
  "Twilio": {
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID_HERE",
    "AuthToken": "YOUR_TWILIO_AUTH_TOKEN_HERE",
    "FromPhoneNumber": "YOUR_TWILIO_FROM_PHONE_NUMBER_HERE",
    "UseMockSms": true
  }
}
