# SQL Server Connection String
CONNECTION_STRING=Server=YOUR_SERVER_HERE;Database=BerberSalonuDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true

# JWT Token Settings
JWT_SECRET=SuperSecretSecurityKeyThatIsLongEnoughToMeetRequirements12345!

# Twilio SMS Credentials
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_FROM_PHONE_NUMBER=YOUR_TWILIO_FROM_PHONE_NUMBER_HERE
TWILIO_USE_MOCK_SMS=true
